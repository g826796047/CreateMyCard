{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harmony-card-module-catalog-v1",
  "type": "object",
  "required": ["schemaVersion", "modules"],
  "properties": {
    "schemaVersion": {"const": "module-catalog-v1"},
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "summary", "variants"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
          "role": {"type": "string"},
          "summary": {"type": "string"},
          "variants": {"type": "array", "minItems": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
